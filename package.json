{
  "name": "flipkart-playwright-tests",
  "version": "2.0.0",
  "description": "Flipkart UI + API + Flaky test suite built with Playwright",
  "author": "QA Automation",
  "license": "ISC",
  "scripts": {
    "test": "npx playwright test --project=UI-Chromium --project=API-Tests",
    "test:ui": "npx playwright test tests/flipkart-ui.spec.js --project=UI-Chromium",
    "test:ui:firefox": "npx playwright test tests/flipkart-ui.spec.js --project=UI-Firefox",
    "test:api": "npx playwright test tests/flipkart-api.spec.js --project=API-Tests",
    "test:flaky": "npx playwright test tests/flipkart-flaky.spec.js --project=Flaky-Suite",
    "test:all": "npx playwright test --project=UI-Chromium --project=API-Tests --project=Flaky-Suite",
    "test:headed": "npx playwright test tests/flipkart-ui.spec.js --project=UI-Chromium --headed",
    "test:debug": "npx playwright test --debug",
    "test:ci": "npx playwright test --reporter=html,list",
    "report": "npx playwright show-report",
    "codegen": "npx playwright codegen https://www.flipkart.com",
    "install:browsers": "npx playwright install --with-deps chromium firefox",
    "ai:flaky": "node ai-flaky-detector/run.js",
    "ai:flaky:analyze": "node ai-flaky-detector/run.js --mode=analyze --runs=3",
    "ai:flaky:heal": "node ai-flaky-detector/run.js --mode=heal",
    "ai:flaky:retry": "node ai-flaky-detector/run.js --mode=retry",
    "ai:flaky:dry": "node ai-flaky-detector/run.js --dry-run",
    "ai:flaky:mcp": "node ai-flaky-detector/run.js --mcp",
    "ai:mcp:heal": "node ai-flaky-detector/run.js --mode=mcp-heal",
    "ai:mcp:heal:dry": "node ai-flaky-detector/run.js --mode=mcp-heal --dry-run",
    "mcp:server": "npx playwright run-test-mcp-server --config=playwright.config.js",
    "ai:heal": "node ai-flaky-detector/selector-healer.js",
    "ai:analyze": "node ai-flaky-detector/flaky-analyzer.js",
    "ai:dashboard": "npx --yes serve dashboard -p 3456",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:serve": "allure serve allure-results",
    "allure:clean": "npx rimraf allure-results allure-report",
    "test:qa": "cross-env ENV=qa npx playwright test",
    "test:staging": "cross-env ENV=staging npx playwright test",
    "test:production": "cross-env ENV=production npx playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "allure-commandline": "^2.42.1",
    "allure-playwright": "^3.10.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2"
  }
}
